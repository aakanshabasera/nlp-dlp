{
  "manifest_version": 3,
  "name": "DLP Guardian",
  "version": "1.0",
  "description": "Detects sensitive data before you send it",
  "permissions": ["activeTab"],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
